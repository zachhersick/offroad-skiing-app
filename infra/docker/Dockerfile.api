FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /workspace

RUN pip install --no-cache-dir uv

COPY . .

RUN uv pip install --system -e packages/agent-core -e apps/api

WORKDIR /workspace/apps/api

CMD ["sh", "-c", "if [ \"$APP_ENV\" = \"production\" ]; then uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}; else uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --reload; fi"]
